# 이 파일을 복사하여 프로젝트 루트에 `.env` 로 저장한 뒤, 실제 키 값을 입력하세요.
# Windows PowerShell 예시:
#   Copy-Item .env.example .env
#
# Google AI Studio(Gemini) API 키: https://aistudio.google.com/apikey
#
# LangChain `ChatGoogleGenerativeAI`는 기본적으로 아래 이름을 사용합니다.
# (호환을 위해 GEMINI_API_KEY 도 코드에서 함께 인식합니다.)

GOOGLE_API_KEY=your-google-api-key-here

# ---- Notion 기록 (선택): 각 기능 페이지에서 「Notion·Google Sheets에 기록」 사용 시
# Notion Integration 생성 → Internal Integration Secret
# 데이터베이스를 해당 Integration 과 「연결」(Connections) 후, DB URL 에서 ID 복사
NOTION_TOKEN=secret_xxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Google Sheets 전체 보관 (선택): 서비스 계정 JSON
# Google Cloud → Sheets API 활성화 → 서비스 계정 생성 → JSON 키 다운로드
# 스프레드시트를 해당 서비스 계정 이메일(…@….iam.gserviceaccount.com)에 「편집자」로 공유
# 아래 둘 중 하나만 설정:
# (A) JSON 파일 경로 (로컬 개발에 편함)
GOOGLE_SHEETS_CREDENTIALS_PATH=
# (B) JSON 전체를 한 줄 문자열로 (Streamlit Cloud Secrets 등 — 줄바꿈 이스케이프 주의)
# GOOGLE_SHEETS_CREDENTIALS_JSON={"type":"service_account",...}

GOOGLE_SHEETS_SPREADSHEET_ID=
